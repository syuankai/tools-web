# ============================================================
# 环境变量示例文件
# 复制本文件为 .env.development / .env.production 后按需修改
# 浏览器侧可读取的变量必须以 VITE_ 为前缀（Vite 规则）
# ============================================================

# ---------- 基础环境 ----------
# 运行环境标识：development（开发） / production（生产）
NODE_ENV=development

# 自定义 dev server 启动 host
VITE_HOST=127.0.0.1

# ---------- 站点信息（用于 SEO / title / 页脚展示） ----------
# 网站名称（导航栏、页脚、页面 title 拼接）
VITE_APP_TITLE=一方工具箱
# 站点简短描述（页脚、页面 title 拼接）
VITE_APP_DESC=一个轻量的在线工具箱
# 站点完整域名（用于 SEO canonical、JWT iss/aud、Functions 代理拼接等）
VITE_SITE_URL=https://tool.fologde.com
# 站长个人站点地址（关于页展示）
VITE_MY_SITE_ADDR=https://www.fologde.com

# ---------- 仓库地址（关于页、评论、提示语展示） ----------
# 本仓库（fork）地址
VITE_GIT_URL=https://github.com/your-name/tools-web
# 上游原始仓库地址
VITE_RAW_GIT_URL=https://github.com/naroat/tools-web

# ---------- HTTP 请求 ----------
# API 前缀，所有请求会拼上该路径
VITE_APP_BASE_API=/v1
# 后端服务地址（最终 baseURL = VITE_SERVE + VITE_APP_BASE_API）
# 本地开发可留空走 Mock 或 Vite 代理
VITE_SERVE=
# 是否走本地 Mock：true 时使用 VITE_APP_BASE_API，否则拼接 VITE_SERVE
VITE_IS_MOCK=true

# ---------- UI / 运营位 ----------
# 第三方反馈互动地址（侧边栏"反馈"按钮跳转）
VITE_FEEDBACK_URL=
# 广告位开关：true 显示广告位，false 隐藏
VITE_ADV_SHOW=false

# ---------- Pollinations.ai（AI 文生图 / 文生文 / 语音） ----------
# Pollinations API Key（AI 工具鉴权使用）
VITE_POLLINATIONS_API_KEY=
# Pollinations 反向代理地址（用于解决跨域 / 国内访问），通常与站点域名同源
VITE_POLLINATIONS_PROXY_URL=https://your-domain.com/proxy
# Pollinations 图生 / 文生图 官方服务地址
VITE_POLLINATIONS_URL=https://gen.pollinations.ai
# Pollinations 文本生成 官方服务地址
VITE_POLLINATIONS_TEXT_URL=https://gen.pollinations.ai
# AI 文生图历史记录最大保留数量（localStorage 中保存的条数）
VITE_AI_IMAGE_HISTORY_MAX=50

# ---------- aitools.cfd（备用免费 AI 文生文） ----------
# aitools.cfd 平台的 API Key（与 Pollinations 复用同一代理）
VITE_AITOOLS_API_KEY=

# ---------- 谷歌登录 ----------
# Google OAuth Client ID（前端用）
VITE_GOOGLE_CLIENT_ID=
# Google OAuth Client Secret（仅前端展示用途，真实校验需后端配合）
VITE_GOOGLE_CLIENT_SECRET=

# ---------- Supabase（数据库 / 鉴权 / 临时聊天） ----------
# Supabase 项目 URL
VITE_SUPABASE_URL=
# Supabase anon public key（前端可公开使用的密钥）
VITE_SUPABASE_ANON_KEY=
